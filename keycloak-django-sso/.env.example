# PostgreSQL
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_USER=postgres

# Per-service DB passwords (must match postgres/init.sql)
KEYCLOAK_DB_PASSWORD=keycloak_pass
D1_DB_PASSWORD=d1_pass
D2_DB_PASSWORD=d2_pass

# Keycloak admin credentials
KEYCLOAK_ADMIN_PASSWORD=admin123

# Keycloak connection (internal Docker network name, for server-to-server calls)
KEYCLOAK_SERVER_URL=http://keycloak:8080
# Keycloak public URL (visible to the browser, for redirects)
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_REALM=app-realm

# D1 OIDC client (matches keycloak/realm-export.json)
D1_OIDC_CLIENT_ID=d1-client
D1_OIDC_CLIENT_SECRET=d1-client-dev-secret
D1_REDIRECT_URI=http://localhost:8001/oidc/callback/

# D1 service account for Keycloak Admin REST API
D1_KC_SERVICE_ACCOUNT_CLIENT_ID=d1-client
D1_KC_SERVICE_ACCOUNT_CLIENT_SECRET=d1-client-dev-secret

# D1 Django
D1_SECRET_KEY=change-me-d1-secret-key-development-only
D1_DATABASE_URL=postgres://d1_user:d1_pass@postgres:5432/d1_db

# D2 OIDC client (matches keycloak/realm-export.json)
D2_OIDC_CLIENT_ID=d2-client
D2_OIDC_CLIENT_SECRET=d2-client-dev-secret
D2_REDIRECT_URI=http://localhost:8002/oidc/callback/

# D2 Django
D2_SECRET_KEY=change-me-d2-secret-key-development-only
D2_DATABASE_URL=postgres://d2_user:d2_pass@postgres:5432/d2_db

# SMTP (required for D2 magic-link email delivery via Keycloak)
SMTP_HOST=
SMTP_PORT=
SMTP_FROM=
SMTP_USER=
SMTP_PASSWORD=
